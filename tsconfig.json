{
  "compilerOptions": {
    "paths": {
      "@server/*": ["./src/server/*"],
      "@/*": ["./src/client/src/*"]
    },
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": false
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/client/dist",
    "src/client/src",
    "test-results",
    "playwright-report"
  ]
}
