# Dependencies (reinstalled in container)
node_modules
.pnpm-store

# Version control and IDE
.git
.gitignore
.vscode
.cursor

# Env and secrets
.env
.env.*

# Build output and logs
*.log
src/client/dist

# Tests and dev tooling (not needed for build/start)
tests

# Separate service (except canonical providers runtime data)
redis/*
!redis/data/
redis/data/*
!redis/data/canonical-providers.json

# Optional: uncomment if you want a smaller context
# scripts
# .npmrc
# *.md
