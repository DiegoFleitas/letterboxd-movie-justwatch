{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git push*": "deny",
      "git push *": "deny",
      "git commit *": "allow",
      "git commit": "allow",
      "git commit *": "allow",
      "git commit --amend*": "ask",
      "git commit -i*": "deny"
    },
    "external_directory": {
      "/tmp/opencode/**": "allow"
    }
  },
  "instructions": [".gitmessage"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
}
