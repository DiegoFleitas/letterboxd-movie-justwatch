# Copy to .env and fill in values. Never commit .env.

# --- Required in production (Fly / Docker with NODE_ENV=production) ---
# Session + signed cookies (@fastify/session). Must be at least 32 characters.
APP_SECRET_KEY=dev-only-session-secret-do-not-use-in-production!!

# Fly.io cache key prefix (set automatically on Fly)
FLY_APP_NAME=

# --- Logger ---
PRETTIFY_LOGS=false

# Sentry (omit SENTRY_DSN to disable). When DSN is set, instrument.ts at the repo root turns on
# SENTRY_CAPTURE_HTTP_5XX by default so diegos-fly-logger reports HTTP 5xx from morgan.
# Set SENTRY_CAPTURE_HTTP_5XX=false to keep Sentry init but skip those captures.
SENTRY_DSN=
SENTRY_CAPTURE_HTTP_5XX=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=
SENTRY_SEND_DEFAULT_PII=false

SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT="movie-justwatch"

# --- Redis ---
FLYIO_REDIS_URL=redis://localhost:6379

# --- APIs (set what you use) ---
# Poster / OMDb proxy
OMDB_API_KEY=
# TMDb + search flow (optional in dev; integration test if set)
MOVIE_DB_API_KEY=

# --- Optional ---
PORT=3000
NODE_ENV=development

# Cache TTL (seconds) for various routes; defaults differ per controller
CACHE_TTL=60

# Letterboxd HTML/CDN outbound fetches (lists, ESI, poster probe). Default 25000 ms if unset.
LETTERBOXD_FETCH_TIMEOUT_MS=

# Optional: fixed User-Agent for Letterboxd/CDN scrapes (default: random desktop UA via user-agents).
SCRAPER_USER_AGENT=

# Shared Axios helper: max automatic retries on HTTP 429 (default 5). Set 0 to never retry.
AXIOS_429_MAX_RETRIES=
# Max seconds to wait before each 429 retry (caps Retry-After; default 60, max 120).
AXIOS_429_MAX_RETRY_AFTER_SECONDS=

# PostHog analytics/error tracking (free tier = 1 project).
# For PRODUCTION: set all four variables below.
# For LOCAL DEVELOPMENT: leave them unset to avoid sending dev traffic to PostHog.
# Events include an "environment" property so you can filter in the PostHog dashboard if needed.
# Frontend (VITE_PUBLIC_* = exposed to client at build time; runtime config is injected by server when POSTHOG_KEY is set).
VITE_PUBLIC_POSTHOG_KEY=""
VITE_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# PostHog (omit to disable)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Jackett alternative search
JACKETT_API_KEY=
JACKETT_API_ENDPOINT=