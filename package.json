{
  "name": "movie-justwatch",
  "version": "1.0.0",
  "description": "Scan a Letterboxd watchlist, see what's streaming in your country—no JustWatch recommendations, optional alternative search.",
  "main": "src/server/main.ts",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "prepare": "husky || true",
    "typecheck": "bunx tsc --noEmit && cd src/client && bunx tsc --noEmit",
    "test": "bunx vitest run",
    "test:coverage": "bunx vitest run --coverage",
    "test:backend": "bunx vitest run tests/backend.integration.test.ts",
    "test:filter": "bunx vitest run tests/filterLogic.test.ts",
    "test:state": "bunx vitest run tests/stateTileManagement.test.ts",
    "test:posthog": "bunx vitest run tests/runtimeConfig.test.ts",
    "test:redis": "bunx vitest run tests/redis.test.ts",
    "test:dedupe": "bunx vitest run tests/providerDeduplication.test.ts",
    "build:providers": "bun redis/scripts/buildCanonicalProviders.ts",
    "build:providers:dry-run": "bun redis/scripts/buildCanonicalProviders.ts --dry-run",
    "update:letterboxd-fixtures": "bun scripts/updateLetterboxdFixtures.ts",
    "sync:api-fixtures-from-redis": "bun scripts/syncApiFixturesFromRedisSnapshot.ts",
    "export-redis": "bun redis/scripts/export-redis-snapshot.ts",
    "seed-redis": "bun redis/scripts/seed-redis-from-snapshot.ts",
    "seed:validate": "bun redis/scripts/validate-redis-snapshot.ts",
    "redis:reset": "bun redis/scripts/reset-redis.ts",
    "seed:refresh:local": "bun run export-redis && bun run seed:validate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "knip": "bunx knip",
    "lint": "bunx eslint . --ext .ts,.tsx",
    "lint:fix": "bunx eslint . --ext .ts,.tsx --fix",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "fe:dev": "bunx vite",
    "fe:serve": "bunx vite preview",
    "devtools": "react-devtools",
    "be:dev": "bun --hot src/server/main.ts",
    "start": "bun src/server/main.ts",
    "build": "bunx vite build",
    "sentry:release:verify-env": "bun -e \"const required = ['SENTRY_AUTH_TOKEN', 'SENTRY_ORG', 'SENTRY_PROJECT', 'SENTRY_RELEASE']; const missing = required.filter((name) => !process.env[name]); if (missing.length) { console.error('Missing required Sentry environment variables.'); console.error('Required:', required.join(', ')); console.error('Missing:', missing.join(', ')); process.exit(1); }\"",
    "sentry:release:new": "bun run sentry:release:verify-env && bunx @sentry/cli releases new \"$SENTRY_RELEASE\"",
    "sentry:release:upload-sourcemaps": "bun run sentry:release:verify-env && bunx @sentry/cli sourcemaps upload src/client/dist/assets --release \"$SENTRY_RELEASE\" --url-prefix \"~/assets\" --validate --wait",
    "sentry:release:finalize": "bun run sentry:release:verify-env && bunx @sentry/cli releases finalize \"$SENTRY_RELEASE\"",
    "sentry:release:frontend": "bun run sentry:release:new && bun run sentry:release:upload-sourcemaps && bun run sentry:release:finalize",
    "dev": "concurrently \"bun run fe:dev\" \"bun run be:dev\" --kill-others",
    "app": "bun -e \"import pkg from './package.json'; console.log(pkg.name)\"",
    "fly:deploy": "flyctl deploy",
    "fly:deploy:with-local-build": "bun run build && flyctl deploy",
    "fly:logs": "flyctl logs -a $(bun -e \"import pkg from './package.json'; console.log(pkg.name)\")",
    "fly:stop": "flyctl scale count 0 -a $(bun -e \"import pkg from './package.json'; console.log(pkg.name)\")",
    "fly:start": "flyctl scale count 1 -a $(bun -e \"import pkg from './package.json'; console.log(pkg.name)\")",
    "fly:ssh": "flyctl ssh console -a $(bun -e \"import pkg from './package.json'; console.log(pkg.name)\")",
    "fly:audit": "bash devops/fly-ops/bin/fly-post-cost-check.sh",
    "fly:inventory": "bash devops/fly-ops/bin/fly-inventory.sh",
    "fly:inventory:json": "bash devops/fly-ops/bin/fly-inventory.sh --json",
    "fly:cost": "bash devops/fly-ops/bin/fly-inventory.sh --cost",
    "fly:redis:audit": "bash devops/fly-ops/bin/fly-redis-audit.sh",
    "fly:memory:check": "bash devops/fly-ops/bin/fly-memory-check.sh",
    "fly:volumes:prune": "bash devops/fly-ops/bin/fly-volumes-prune.sh",
    "fly:redis:prune": "bash devops/fly-ops/bin/fly-redis-prune.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fly-examples/movie-justwatch.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/fly-examples/movie-justwatch/issues"
  },
  "homepage": "https://github.com/fly-examples/movie-justwatch#readme",
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "bunx eslint --fix"
    ],
    "*.{js,jsx,json,css,md,yml,yaml,html}": "prettier --write"
  },
  "overrides": {
    "eslint": "10.4.0",
    "@eslint/js": "10.0.1",
    "cross-spawn": ">=6.0.6",
    "lodash": ">=4.17.23",
    "got": ">=11.8.5",
    "on-headers": ">=1.1.0",
    "diff": ">=8.0.3",
    "esbuild": ">=0.25.0",
    "electron": ">=35.7.5"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.3",
    "@posthog/react": "^1.10.3",
    "@sentry/node": "^10.62.0",
    "@sentry/react": "^10.62.0",
    "@tanstack/react-virtual": "^3.14.4",
    "axios": "^1.18.1",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "framer-motion": "^12.42.0",
    "https-proxy-agent": "^9.1.0",
    "ioredis": "^5.11.1",
    "posthog-js": "^1.396.2",
    "posthog-node": "5.38.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "user-agents": "^2.1.106",
    "zod": "4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/cli": "^3.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "react-devtools": "^7.0.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
